<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <!-- Coin Rank -->
    <TextView
        android:id="@+id/rankTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1"
        android:paddingRight="7dp"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="4dp"/>

    <!-- Coin Logo -->
    <ImageView
        android:id="@+id/cryptoIcon"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginStart="12dp"
        android:layout_marginRight="20dp"
        app:layout_constraintStart_toEndOf="@id/rankTv"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />

    <!-- Coin Name -->
    <TextView
        android:id="@+id/cryptoName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Bitcoin"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingLeft="20dp"
        app:layout_constraintStart_toEndOf="@id/cryptoIcon"
        app:layout_constraintTop_toTopOf="@id/cryptoIcon"
        app:layout_constraintEnd_toStartOf="@id/cryptoPrice"
        android:ellipsize="end"
        android:singleLine="true"/>

    <!-- Coin Symbol -->
    <TextView
        android:id="@+id/cryptoSymbol"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="BTC"
        android:textSize="14sp"
        android:textColor="#888888"
        android:paddingLeft="20dp"
        app:layout_constraintStart_toStartOf="@id/cryptoName"
        app:layout_constraintTop_toBottomOf="@id/cryptoName"
        app:layout_constraintEnd_toStartOf="@id/cryptoPrice"
        android:ellipsize="end"
        android:singleLine="true"/>

    <!-- Current Price / 24h Change -->
    <TextView
        android:id="@+id/cryptoPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$27,345"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/cryptoChange"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+2.5%"
        android:textSize="14sp"
        android:textColor="@android:color/holo_green_dark"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cryptoPrice"/>

</androidx.constraintlayout.widget.ConstraintLayout>